# MongoDB Database
# Get your MongoDB connection string from MongoDB Atlas (https://www.mongodb.com/cloud/atlas)
# Replace <username>, <password>, and add your database name
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/electrical_estimates?retryWrites=true&w=majority

# NextAuth Configuration
# For development, use http://localhost:3000
# For production, use your deployed URL
NEXTAUTH_URL=http://localhost:3000

# NextAuth Secret
# Generate a random secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here

# Email Provider (for Magic Links)
# Using Resend.com (Free tier: 3000 emails/month)
# Sign up at https://resend.com and get your API key
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=your-resend-api-key-here
EMAIL_FROM=noreply@yourdomain.com

# AI Providers (Server-side only - shared across all users)
# Get your OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Get your Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Optional: Google OAuth (for Sign in with Google)
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Enable Google OAuth in the UI
# NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true

# Optional: GitHub OAuth (for Sign in with GitHub)
# Create OAuth app at https://github.com/settings/developers
# GITHUB_ID=your-github-client-id
# GITHUB_SECRET=your-github-client-secret

# Optional: Google Places Autocomplete (for address suggestions)
# Enable the Places API at https://console.cloud.google.com/apis/library/places-backend.googleapis.com
# Create an API key at https://console.cloud.google.com/apis/credentials
# NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# Inbound Email Webhook (for auto-creating estimates from emails)
# Resend API key (starts with re_) — used to fetch inbound email content
RESEND_API_KEY=
# Resend webhook signing secret (from Resend dashboard → Webhooks)
RESEND_WEBHOOK_SECRET=
# Your account email (used to look up your userId for draft estimates)
INBOUND_ESTIMATE_USER_EMAIL=
